BOOKSTORE_APP_NAME=Online Bookstore API
BOOKSTORE_API_V1_PREFIX=/api/v1
BOOKSTORE_DEBUG=false
BOOKSTORE_TESTING=false

BOOKSTORE_SECRET_KEY=change-this-secret-key
BOOKSTORE_ALGORITHM=HS256
BOOKSTORE_ACCESS_TOKEN_EXPIRE_MINUTES=120

BOOKSTORE_MONGODB_URL=mongodb://localhost:27017
BOOKSTORE_MONGODB_DB_NAME=online_bookstore

BOOKSTORE_RATE_LIMIT_REQUESTS=60
BOOKSTORE_RATE_LIMIT_WINDOW_SECONDS=60

BOOKSTORE_ADMIN_EMAIL=admin@bookstore.com
BOOKSTORE_ADMIN_PASSWORD=Admin@12345
